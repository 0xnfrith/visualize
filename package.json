{
  "name": "visualize",
  "version": "0.3.4",
  "description": "Diagram-rendering canvas plugin for Claude Code",
  "license": "Apache-2.0",
  "type": "module",
  "bin": "./server.ts",
  "scripts": {
    "start": "bun install --no-summary && bun run scripts/build-web.ts && bun server.ts",
    "build:web": "bun run scripts/build-web.ts",
    "dev:web": "bun --hot run scripts/build-web.ts --watch",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "bump": "bun run scripts/bump.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tldraw": "^3.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"
  }
}
